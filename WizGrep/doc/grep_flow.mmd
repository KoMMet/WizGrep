```mermaid
flowchart TD
    Start(["ユーザー：「開始」クリック"])
    Validate["GrepSettingsDialogViewModel<br>Validate()"]
    CheckValid{"検証成功?"}
    Error["エラー表示 / キャンセル"]
    StartSearch["MainViewModel<br>StartSearchAsync()"]
    TaskRun["Task.Run()<br>(バックグラウンドスレッド)"]
    ExecuteGrep["GrepService.ExecuteGrepAsync()"]
    PreCheck["キーワード事前検証 /<br>インデックス削除(再構築時)"]
    LoopStart{"ファイル走査ループ"}
    CheckIndex{"インデックス有効？<br>(タイムスタンプ一致)"}
    UseIndex["インデックスから<br>テキスト復元"]
    ParseFile["FileReaderServiceで<br>ファイルパース"]
    MatchText["キーワードマッチング<br>(AND / OR / 正規表現)"]
    ReportUI["マッチ結果をUIに通知<br>(RealTimeDisplay)"]
    SaveIndex["インデックス保存<br>(GrepIndex.txt / Timestamp)"]
    Finish(["検索完了 (UI更新)"])

    Start --> Validate
    Validate --> CheckValid
    CheckValid -- No --> Error
    CheckValid -- Yes --> StartSearch
    StartSearch --> TaskRun
    TaskRun --> ExecuteGrep
    ExecuteGrep --> PreCheck
    PreCheck --> LoopStart
    LoopStart -- 次のファイル --> CheckIndex
    CheckIndex -- 一致 --> UseIndex
    CheckIndex -- 不一致 --> ParseFile
    ParseFile --> MatchText
    UseIndex --> MatchText
    MatchText --> ReportUI
    ReportUI --> LoopStart
    LoopStart -- 完了 --> SaveIndex
    SaveIndex --> Finish
```