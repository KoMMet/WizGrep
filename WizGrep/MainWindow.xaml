<?xml version="1.0" encoding="utf-8"?>

<Window
    x:Class="WizGrep.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:WizGrep.Models"
    xmlns:helpers="using:WizGrep.Helpers"
    mc:Ignorable="d"
    Title="WizGrep">

    <Window.SystemBackdrop>
        <DesktopAcrylicBackdrop/>
    </Window.SystemBackdrop>

    <Grid x:Name="RootGrid">
        <Grid.Resources>
            <helpers:ResultColumnWidthsHelper x:Key="ResultColumnWidthsHelper" />
        </Grid.Resources>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- TitleVar/MenuBar -->
        <Grid Grid.Row="0" Padding="16,8" Background="{ThemeResource LayerFillColorDefaultBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" x:Uid="MainTitle" FontSize="20" FontWeight="Bold" VerticalAlignment="Center" />

            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
                <Button x:Uid="GrepSettingsButton"
                        IsEnabled="{x:Bind ViewModel.IsNotSearching, Mode=OneWay}"
                        Click="OnGrepSettingsClick" />
                <Button x:Uid="WizGrepSettingsButton"
                        IsEnabled="{x:Bind ViewModel.IsNotSearching, Mode=OneWay}"
                        Click="OnWizGrepSettingsClick" />
                <Button x:Uid="CancelButton"
                        Command="{x:Bind ViewModel.CancelSearchCommand}"
                        Visibility="{x:Bind ViewModel.CancelVisibility, Mode=OneWay}"
                        Background="{ThemeResource SystemFillColorCriticalBrush}" />
            </StackPanel>
        </Grid>

        <!-- Progress -->
        <Grid Grid.Row="1" Padding="16,8" Visibility="{x:Bind ViewModel.ProgressVisibility, Mode=OneWay}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <ProgressBar Grid.Row="0" IsIndeterminate="True" />
            <TextBlock Grid.Row="1" Margin="0,4,0,0"
                       Text="{x:Bind ViewModel.ProgressText, Mode=OneWay}"
                       TextTrimming="CharacterEllipsis" />
        </Grid>

        <!-- MainContent Left Right Pain -->
        <Grid Grid.Row="2" Padding="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- LeftPain: Match Files -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" x:Uid="LeftPainHeader" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <Button Grid.Column="1" x:Uid="LeftPainExport" Command="{x:Bind ViewModel.ExportFilesCommand}" FontSize="12" />
                </Grid>

                <Border Grid.Row="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="4">
                    <ListView ItemsSource="{x:Bind ViewModel.MatchedFiles, Mode=TwoWay}"
                              SelectionMode="None" ShowsScrollingPlaceholders="True"
                              ScrollViewer.HorizontalScrollBarVisibility="Auto"
                              ScrollViewer.HorizontalScrollMode="Auto">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Left" />
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="x:String">
                                <TextBlock Text="{x:Bind}" IsTextSelectionEnabled="True" TextWrapping="NoWrap"/>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Border>
            </Grid>

            <!-- Separator -->
            <Border Grid.Column="1" Width="1" Background="{ThemeResource CardStrokeColorDefaultBrush}" />

            <!-- RightPane: Grep Result Details -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" x:Uid="SearchResultsHeader" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="{x:Bind ViewModel.ResultCountText, Mode=OneWay}"
                                   VerticalAlignment="Center" FontSize="12"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <Button x:Uid="SearchResultsExport" Command="{x:Bind ViewModel.ExportResultsCommand}" FontSize="12" />
                    </StackPanel>
                </Grid>

                <Border Grid.Row="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="4">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!-- Column Header (Resizable by Dragging) -->
                        <Grid Grid.Row="0" x:Name="ResultHeaderGrid" Padding="12,6"
                              BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                              BorderThickness="0,0,0,1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition x:Name="ResultCol0" Width="200" MinWidth="80" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition x:Name="ResultCol1" Width="120" MinWidth="80" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" x:Uid="ResultColumnFileName"
                                       FontSize="12" FontWeight="SemiBold"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <helpers:ColumnSplitterHelper Grid.Column="1" Tag="0"
                                PointerPressed="OnSplitterPointerPressed"
                                PointerMoved="OnSplitterPointerMoved"
                                PointerReleased="OnSplitterPointerReleased" />
                            <TextBlock Grid.Column="2" x:Uid="ResultColumnPosition" 
                                       FontSize="12" FontWeight="SemiBold"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <helpers:ColumnSplitterHelper Grid.Column="3" Tag="1"
                                PointerPressed="OnSplitterPointerPressed"
                                PointerMoved="OnSplitterPointerMoved"
                                PointerReleased="OnSplitterPointerReleased" />
                            <TextBlock Grid.Column="4" x:Uid="ResultColumnContent"
                                       FontSize="12" FontWeight="SemiBold"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </Grid>

                        <!-- Search Results List -->
                        <ListView Grid.Row="1" ItemsSource="{x:Bind ViewModel.GrepResults, Mode=TwoWay}"
                                  SelectionMode="None"
                                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                  ScrollViewer.HorizontalScrollMode="Auto">
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Left" />
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="models:GrepResult">
                                    <Grid Padding="4,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="8" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="8" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{x:Bind FileName}" IsTextSelectionEnabled="True" TextWrapping="NoWrap"
                                                   Width="{Binding FileNameWidth, Source={StaticResource ResultColumnWidthsHelper}, Mode=OneWay}"
                                                   TextTrimming="CharacterEllipsis"
                                                   ToolTipService.ToolTip="{x:Bind FilePath}" />
                                        <TextBlock Grid.Column="2" Text="{x:Bind Location}" IsTextSelectionEnabled="True" TextWrapping="NoWrap"
                                                   Width="{Binding LocationWidth, Source={StaticResource ResultColumnWidthsHelper}, Mode=OneWay}"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                        <TextBlock Grid.Column="4" Text="{x:Bind Content}" IsTextSelectionEnabled="True" TextWrapping="NoWrap"
                                                   ToolTipService.ToolTip="{x:Bind Content}" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <!-- Status Bar -->
        <Grid Grid.Row="3" Padding="16,8" Background="{ThemeResource LayerFillColorDefaultBrush}">
            <TextBlock Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}" />
        </Grid>
    </Grid>
</Window>